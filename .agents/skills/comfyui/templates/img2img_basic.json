{
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "cfg": "{{cfg}}",
      "denoise": "{{denoise}}",
      "latent_image": ["13", 0],
      "model": ["4", 0],
      "negative": ["7", 0],
      "positive": ["6", 0],
      "sampler_name": "{{sampler}}",
      "scheduler": "normal",
      "seed": "{{seed}}",
      "steps": "{{steps}}"
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{model}}"
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["4", 1],
      "text": "{{prompt}}"
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["4", 1],
      "text": "{{negative_prompt}}"
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["3", 0],
      "vae": ["4", 2]
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "comfyui_output",
      "images": ["8", 0]
    }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{input_image}}"
    }
  },
  "11": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["10", 0],
      "vae": ["4", 2]
    }
  },
  "13": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "batch_size": "{{batch_size}}",
      "height": "{{height}}",
      "width": "{{width}}"
    }
  }
}
